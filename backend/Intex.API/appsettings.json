{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FrontendUrl": "http://localhost:3000",
  "ConnectionStrings": {
    "AppConnection": ""
  },
  "GenerateDefaultIdentityAdmin": {
    "Email": "admin@intex.local",
    "Password": ""
  },
  "GenerateDefaultIdentityDonor": {
    "Email": "donor@intex.local",
    "Password": ""
  },
  "GenerateDefaultIdentityMfa": {
    "Email": "mfa@intex.local",
    "Password": ""
  },
  "DonorChurnInference": {
    "ModelPath": "ml-runtime/donor_churn.onnx",
    "Threshold": 0.49,
    "MinHistoryDays": 30
  },
  "ReintegrationReadiness": {
    "ModelPath": "ml-runtime/reintegration_model.onnx",
    "Threshold": 0.5
  },
  "DonorUpsell": {
    "ModelPath": "ml-runtime/donor_upsell_model.onnx",
    "Threshold": 0.30
  },
  "InterventionEffectiveness": {
    "ModelPath": "ml-runtime/intervention_effectiveness_model.onnx",
    "Threshold": 0.45
  },
  "SocialMediaDonations": {
    "ClassificationModelPath": "ml-runtime/social_media_donations_classification_model.onnx",
    "RegressionModelPath": "ml-runtime/social_media_donations_regression_model.onnx",
    "ClassificationThreshold": 0.2818
  },
  "ResidentRisk": {
    "ClassificationModelPath": "ml-runtime/resident_risk_classification_model.onnx",
    "RegressionModelPath": "ml-runtime/resident_risk_regression_model.onnx",
    "ClassificationThreshold": 0.6713,
    "RegressionHighRiskThreshold": 60.0
  }
}
